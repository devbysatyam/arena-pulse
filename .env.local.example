# NexArena — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Gemini AI (Google Generative AI) ───────────────────────────────────────
# Get your key at: https://makersuite.google.com/app/apikey
# The app uses a rotation pool — add 2 backup keys to avoid rate limits.
NEXT_PUBLIC_GEMINI_API_KEY=your_primary_gemini_api_key_here
NEXT_PUBLIC_GEMINI_API_KEY_2=your_backup_gemini_key_here
NEXT_PUBLIC_GEMINI_API_KEY_3=your_third_gemini_key_here

# ─── Firebase (Web SDK) ──────────────────────────────────────────────────────
# Create a project at: https://console.firebase.google.com
# Enable: Authentication (Email/Password and Google), Firestore, and Storage.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# ─── Admin Setup (Firebase Auth — NOT stored in code) ────────────────────────
# Create an admin user in Firebase Console:
#   1. Firebase Console → Authentication → Users → Add User
#   2. Enter email (e.g. admin@yourdomain.com) and a strong password
#   3. Copy the UID shown after creation
#   4. Cloud Firestore → Create document: admins/{uid} with field: role = "admin"
# The admin login screen uses Firebase Auth — credentials NEVER in source code.

# ─── Google Maps Embed API ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps Embed API only. Restrict key to your domain.
NEXT_PUBLIC_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Google Analytics 4 (Optional) ──────────────────────────────────────────
# Get from: https://analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Firestore Collection Structure ──────────────────────────────────────────
# crowd/{stadiumId}            ← live crowd density (admin-writable)
# notifications/{id}           ← admin broadcasts to fans
# stadiums/{stadiumId}/stalls/ ← food stall data
# orders/{orderId}             ← fan food orders with status
# stadiums/{stadiumId}/incidents/ ← admin incident reports
# admins/{uid}                 ← role check after Firebase Auth sign-in
