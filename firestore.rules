rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user has admin role in the admins collection
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Notifications (Admin Write / Public Read) ──────────────────────────────
    // Notifications are publicly readable (fans + guests)
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Crowd Data (Admin Write / Public Read) ────────────────────────────────
    // Crowd density data is publicly readable (needed for guest heatmap)
    match /crowd/{stadiumId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Stalls & Incidents (Admin Write / Public Read) ─────────────────────────
    // Basic venue info is public
    match /stadiums/{stadiumId}/stalls/{stallId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /stadiums/{stadiumId}/incidents/{incidentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Orders (User Read/Write Own / Admin Read/Write All) ────────────────────
    match /orders/{orderId} {
      allow read, write: if (request.auth != null && request.auth.uid == resource.data.userId)
                          || isAdmin();
      allow create: if request.auth != null;
    }

    // ── Admins Collection (Private) ──────────────────────────────────────────
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only manageable via Firebase Console/Backend
    }

    // ── Default: Deny All ────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
